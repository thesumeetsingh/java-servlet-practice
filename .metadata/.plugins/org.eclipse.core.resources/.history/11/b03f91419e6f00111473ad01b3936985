
import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import java.io.IOException;
import java.io.PrintWriter;

/**
 * Servlet implementation class FirstServletApp
 */
@WebServlet("/firstServlet")
public class FirstServletApp extends HttpServlet {
	public FirstServletApp() {
		System.out.println("servlet obj is created internally by container");
	}
	private static final long serialVersionUID = 1L;

	/**
	 * @see HttpServlet#doPost(HttpServletRequest request, HttpServletResponse response)
	 */
	public void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		String username= request.getParameter("username");
		String usercity= request.getParameter("city");
		
		
		PrintWriter writer=response.getWriter();
		
//		writer.println("Hello "+username+" Your entered city is: "+usercity);
		writer.println("<html><head><title>Form submitted</title></head><body><h1>Hello "+username+" </h1><br><p>from "+usercity+"</p></body></html>");
		writer.close();
		
		// TODO Auto-generated method stub
	}

}
